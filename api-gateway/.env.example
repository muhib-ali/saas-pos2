# API Gateway Configuration
API_GATEWAY_PORT=3002
NODE_ENV=development

# Service URLs
AUTHENTICATION_SERVICE_URL=http://localhost:3001
SYSTEM_USER_SERVICE_URL=http://localhost:3000
AUTHORIZATION_SERVICE_URL=http://localhost:3003

# Service Configuration
SERVICE_TIMEOUT=30000
SERVICE_RETRY_ATTEMPTS=3

# CORS Configuration
CORS_ORIGIN=*

# Logging Configuration
LOG_LEVEL=info

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
